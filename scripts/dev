#!/bin/sh
set -eu

if [ -f .env ]; then
  set -a
  . ./.env
  set +a
fi

echo "Starting Postgres..."
docker compose up -d postgres

echo "Waiting for Postgres to become healthy..."
while [ "$(docker inspect --format '{{.State.Health.Status}}' "$(docker compose ps -q postgres)")" != "healthy" ]; do
  sleep 1
done

echo "Starting todoPlayground at http://localhost:8080"
TODO_STORE="${TODO_STORE:-postgres}" go run .
